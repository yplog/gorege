{
  "dimensions": [
    { "name": "plan", "values": ["free", "pro", "enterprise"] },
    { "name": "region", "values": ["eu", "us", "apac"] }
  ],
  "rules": [
    {
      "action": "DENY",
      "name": "deny-free-eu-gdpr",
